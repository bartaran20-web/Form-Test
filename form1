<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Services Inquiry Form</title>
        <style>

        :root {
            --color-1: #FCC0DA;
            --color-2: #FEE7F1;
            --color-3: #F863A3;
            --color-4: #F40B70;
            --color-5: #700534;
            --color-6: #18010B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, var(--color-6) 0%, var(--color-5) 50%, var(--color-4) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(3px 3px at 30px 40px, var(--color-1), transparent),
                radial-gradient(2px 2px at 90px 70px, var(--color-2), transparent);
            background-repeat: repeat;
            background-size: 200px 120px;
            animation: float 30s infinite linear;
            z-index: -1;
            opacity: 0.3;
        }

        @keyframes float {
            0% { transform: translateX(0) translateY(0); }
            100% { transform: translateX(-200px) translateY(-120px); }
        }

        .form-wrapper {
            max-width: 600px;
            width: 100%;
            position: relative;
        }

        .logo-section {
            text-align: center;
            margin-bottom: 30px;
            padding: 20px;
        }

        .logo {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, var(--color-3), var(--color-4));
            border-radius: 24px;
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            box-shadow: 0 15px 35px rgba(244, 11, 112, 0.4);
            border: 2px solid rgba(252, 192, 218, 0.5);
        }

        .form-title {
            color: white;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 5px;
            text-shadow: 0 2px 10px rgba(244, 11, 112, 0.4);
        }

        .form-subtitle {
            color: rgba(252, 192, 218, 0.9);
            font-size: 16px;
            font-weight: 500;
        }

        .form-container {
            background: rgba(254, 231, 241, 0.2);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(252, 192, 218, 0.4);
            border-radius: 28px;
            box-shadow: 
                0 30px 60px rgba(24, 1, 11, 0.3),
                0 0 0 1px rgba(252, 192, 218, 0.2);
            overflow: hidden;
            animation: slideIn 0.8s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(40px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .progress-bar {
            height: 5px;
            background: rgba(252, 192, 218, 0.3);
            border-radius: 3px;
            overflow: hidden;
            margin: 0 40px 35px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--color-1), var(--color-3));
            width: 0%;
            transition: width 0.4s ease;
            box-shadow: 0 0 15px var(--color-3);
        }

        .form-body {
            padding: 40px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            color: var(--color-5);
            margin-bottom: 10px;
            font-size: 15px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 16px 20px;
            border: 1px solid rgba(252, 192, 218, 0.4);
            border-radius: 16px;
            font-size: 16px;
            background: rgba(254, 231, 241, 0.8);
            backdrop-filter: blur(15px);
            transition: all 0.3s ease;
            color: var(--color-5);
            font-weight: 500;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--color-3);
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 0 0 3px rgba(248, 99, 163, 0.2);
            transform: translateY(-1px);
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .checkbox-group {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 20px;
            background: rgba(252, 192, 218, 0.2);
            border-radius: 12px;
            border: 1px solid rgba(252, 192, 218, 0.3);
        }

        .checkbox-group input[type="checkbox"] {
            width: auto;
            margin: 0;
            transform: scale(1.2);
            accent-color: var(--color-4);
            order: -1;
        }

        .checkbox-group label {
            margin: 0;
            font-weight: 500;
            cursor: pointer;
            color: var(--color-5);
        }

        .form-footer {
            padding: 0 40px 40px;
            text-align: center;
        }

        .submit-btn {
            background: linear-gradient(135deg, var(--color-3), var(--color-4));
            color: white;
            border: none;
            padding: 20px 50px;
            border-radius: 50px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 10px 30px rgba(244, 11, 112, 0.4);
        }

        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(244, 11, 112, 0.5);
        }

        .submit-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .success-message,
        .error-message {
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 20px;
            display: none;
            font-weight: 500;
            backdrop-filter: blur(15px);
        }

        .success-message {
            background: rgba(252, 192, 218, 0.3);
            color: var(--color-5);
            border: 1px solid var(--color-1);
        }

        .error-message {
            background: rgba(112, 5, 52, 0.2);
            color: var(--color-1);
            border: 1px solid var(--color-3);
        }

        @media (max-width: 768px) {
            .form-row { grid-template-columns: 1fr; }
            .form-body { padding: 30px 25px; }
            .form-footer { padding: 0 25px 30px; }
            #google_translate_element { 
                position: static; 
                margin: 0 auto 20px; 
                display: block; 
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <div id="order-form-container">
    </div>
    <div class="form-wrapper">

        <!-- Logo + Title above form -->
        <div class="logo-section">
            <div class="logo"><img src="logoM&A.png" alt="Company Logo" width="120 px" height="120 px" style="display: block; margin: 0 auto;"></div>
            <h1 class="form-title">Services Inquiry Form</h1>
            <p class="form-subtitle">Complete all fields for IT business consultation</p>
        </div>

        <div class="form-container">
            <div class="progress-bar">
                <div class="progress-fill" id="progressFill"></div>
            </div>

            <form id="orderForm" class="form-body">
                <div class="success-message" id="successMessage">
                    ✅ Thank you! Your information has been submitted successfully.
                </div>
                <div class="error-message" id="errorMessage">
                    ⚠️ Please fill all required fields correctly.
                </div>

                <div class="form-group">
                    <label for="companyName">Company Name *</label>
                    <input type="text" id="companyName" name="companyName" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="contactName">Contact Person *</label>
                        <input type="text" id="contactName" name="contactName" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone Number *</label>
                        <input type="tel" id="phone" name="phone" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Email Address *</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div class="form-group">
                    <label for="industry">Industry / Sector *</label>
                    <select id="industry" name="industry" required>
                        <option value="">Select Industry</option>
                        <option value="finance">Finance</option>
                        <option value="healthcare">Healthcare</option>
                        <option value="retail">Retail</option>
                        <option value="manufacturing">Manufacturing</option>
                        <option value="technology">Technology</option>
                        <option value="other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="servicesNeeded">Services Needed *</label>
                    <textarea id="servicesNeeded" name="servicesNeeded" rows="4" required 
                        placeholder="Describe the IT services you need..."></textarea>
                </div>

                <div class="form-group">
                    <label for="timeline">Project Timeline *</label>
                    <textarea id="timeline" name="timeline" rows="4" required placeholder="your expected project timeline..."></textarea>
                </div>
                
                <div class="form-group">
                    <label for="budgetRange">Budget Range *</label>
                    <textarea id="budgetRange" name="budgetRange" rows="4" required placeholder="your expected budget range..."></textarea>
                </div>

                <div class="form-group checkbox-group">
                    <input type="checkbox" id="urgent" name="urgent">
                    <label for="urgent">This is an urgent requirement</label>
                </div>

                <div class="form-footer">
                    <button type="submit" class="submit-btn" id="submitBtn">
                        Submit Request
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>

        const WEBHOOK_URL = 'https://your-n8n-webhook-url.com/webhook/it-business-form';

        const form = document.getElementById('orderForm');
        const submitBtn = document.getElementById('submitBtn');
        const progressFill = document.getElementById('progressFill');
        const successMessage = document.getElementById('successMessage');
        const errorMessage = document.getElementById('errorMessage');

        const requiredFields = ['companyName', 'contactName', 'phone', 'email', 'industry', 'companySize', 'annualRevenue', 'servicesNeeded', 'timeline', 'budgetRange'];
        requiredFields.forEach((fieldId, index) => {
            const field = document.getElementById(fieldId);
            field.addEventListener('input', () => {
                if (field.value.trim()) {
                    progressFill.style.width = `${Math.min(((index + 1) / requiredFields.length) * 100, 100)}%`;
                }
            });
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            successMessage.style.display = 'none';
            errorMessage.style.display = 'none';
            
            submitBtn.disabled = true;
            submitBtn.textContent = 'Submitting...';

            try {
                const formData = new FormData(form);
                const data = Object.fromEntries(formData);
                data.submissionTime = new Date().toISOString();
                data.language = document.querySelector('.goog-te-combo')?.value || 'en';

                const response = await fetch(WEBHOOK_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    successMessage.style.display = 'block';
                    form.reset();
                    progressFill.style.width = '0%';
                } else {
                    throw new Error('Submission failed');
                }
            } catch (error) {
                errorMessage.style.display = 'block';
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Submit Request';
            }
        });

        document.getElementById('phone').addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            if (value.length >= 10) {
                value = value.replace(/(\d{3})(\d{3})(\d{4})/, '($1) $2-$3');
            }
            e.target.value = value;
        });

        document.getElementById('companyName').focus();
    </script>
</body>
</html>
